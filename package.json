{
  "name": "cdktn-provider-features-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo scenarios for CDK Terrain PR #296 provider plugin-protocol feature bindings generated from current Terraform/OpenTofu schemas.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "use:prhead": "node scripts/use-prhead-cdktn.js",
    "schema:aws": "bash scripts/capture-aws-schema.sh",
    "inspect:schema": "node scripts/inspect-aws-schema.js schema/aws-provider-schema.json",
    "assert:prhead-deps": "node scripts/assert-prhead-deps.js",
    "assert:generated-features": "node scripts/assert-generated-features.js schema/aws-provider-schema.json",
    "typecheck": "tsc --noEmit --checkers 1",
    "generate:aws": "node scripts/cdktn.js get --language typescript --output .gen --force",
    "synth:functions-ephemeral": "cd examples/functions-ephemeral && node ../../scripts/cdktn.js synth",
    "synth:functions-only": "cd examples/functions-only && node ../../scripts/cdktn.js synth",
    "synth:ephemeral-writeonly-secret": "cd examples/ephemeral-writeonly-secret && node ../../scripts/cdktn.js synth",
    "synth:mixins-s3": "cd examples/mixins-s3 && node ../../scripts/cdktn.js synth",
    "synth:mixins-data-recovery": "cd examples/mixins-data-recovery && node ../../scripts/cdktn.js synth",
    "synth:mixins-aspect-instance": "cd examples/mixins-aspect-instance && node ../../scripts/cdktn.js synth",
    "synth:l2-kinesis-stream": "cd examples/l2-kinesis-stream && node ../../scripts/cdktn.js synth",
    "synth:l2-secretsmanager-secret": "cd examples/l2-secretsmanager-secret && node ../../scripts/cdktn.js synth",
    "synth:l2-ec2-cidr-split": "cd examples/l2-ec2-cidr-split && node ../../scripts/cdktn.js synth",
    "plan:functions-ephemeral": "cd examples/functions-ephemeral/cdktf.out/stacks/functions-ephemeral && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:functions-only": "cd examples/functions-only/cdktf.out/stacks/functions-only && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:ephemeral-writeonly-secret": "cd examples/ephemeral-writeonly-secret/cdktf.out/stacks/ephemeral-writeonly-secret && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:mixins-s3": "cd examples/mixins-s3/cdktf.out/stacks/mixins-s3 && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:mixins-data-recovery": "cd examples/mixins-data-recovery/cdktf.out/stacks/mixins-data-recovery && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:mixins-aspect-instance": "cd examples/mixins-aspect-instance/cdktf.out/stacks/mixins-aspect-instance && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:l2-kinesis-stream": "cd examples/l2-kinesis-stream/cdktf.out/stacks/l2-kinesis-stream && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:l2-secretsmanager-secret": "cd examples/l2-secretsmanager-secret/cdktf.out/stacks/l2-secretsmanager-secret && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "plan:l2-ec2-cidr-split": "cd examples/l2-ec2-cidr-split/cdktf.out/stacks/l2-ec2-cidr-split && ${TERRAFORM_BINARY_NAME:-terraform} init -input=false && ${TERRAFORM_BINARY_NAME:-terraform} plan -input=false -refresh=false",
    "synth:all": "pnpm run synth:functions-only && pnpm run synth:functions-ephemeral && pnpm run synth:ephemeral-writeonly-secret && pnpm run synth:mixins-s3 && pnpm run synth:mixins-data-recovery && pnpm run synth:mixins-aspect-instance && pnpm run synth:l2-kinesis-stream && pnpm run synth:l2-secretsmanager-secret && pnpm run synth:l2-ec2-cidr-split",
    "plan:all": "pnpm run plan:functions-only && pnpm run plan:functions-ephemeral && pnpm run plan:ephemeral-writeonly-secret && pnpm run plan:mixins-s3 && pnpm run plan:mixins-data-recovery && pnpm run plan:mixins-aspect-instance && pnpm run plan:l2-kinesis-stream && pnpm run plan:l2-secretsmanager-secret && pnpm run plan:l2-ec2-cidr-split",
    "check": "pnpm run generate:aws && pnpm run synth:all"
  },
  "dependencies": {
    "cdktn": "file:/data/pr-check/cdk-terrain-296-latest/packages/cdktn",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "7.0.2"
  },
  "packageManager": "pnpm@11.5.2"
}
